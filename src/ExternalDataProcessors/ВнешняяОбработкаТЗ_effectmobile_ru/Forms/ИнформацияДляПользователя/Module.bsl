&НаСервере
// Обработчик события ПриСозданииНаСервере формы
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	МассивРеквизитов = Новый Массив;
	
	ОписаниеТиповСтрока = Новый ОписаниеТипов("Строка");
	
	РеквизитТекстЗаголовка = Новый РеквизитФормы("ТекстЗаголовка", ОписаниеТиповСтрока, , "ТекстЗаголовка");
	МассивРеквизитов.Добавить(РеквизитТекстЗаголовка);
	
	РеквизитСообщение = Новый РеквизитФормы("Сообщение", ОписаниеТиповСтрока, , "Сообщение");
	МассивРеквизитов.Добавить(РеквизитСообщение);
	
	ИзменитьРеквизиты(МассивРеквизитов);

	ЭтотОбъект.ТекстЗаголовка = Параметры.Заголовок;
	ЭтотОбъект.Сообщение = Параметры.Сообщение;
	
	// Устанавливаем заголовок формы
	ЭтотОбъект.Заголовок = "Информация для пользователя";
	ЭтотОбъект.АвтоЗаголовок = Ложь;
	
	// Добавляем элементы формы
	ДекорацияЗаголовка = Элементы.Добавить("ДекорацияЗаголовка", Тип("ДекорацияФормы"));
	ДекорацияЗаголовка.Заголовок = ЭтотОбъект.ТекстЗаголовка;
	ДекорацияЗаголовка.РастягиватьПоГоризонтали = Истина;
	ДекорацияЗаголовка.Шрифт = Новый Шрифт(ДекорацияЗаголовка.Шрифт, , Истина, Истина);
	
	ДекорацияСообщения = Элементы.Добавить("ДекорацияСообщения", Тип("ДекорацияФормы"));
	ДекорацияСообщения.Заголовок = ЭтотОбъект.Сообщение;
	ДекорацияСообщения.РастягиватьПоГоризонтали = Истина;
	ДекорацияСообщения.РастягиватьПоВертикали = Истина;
	ДекорацияСообщения.Высота = 10;
	
КонецПроцедуры

&НаСервере
// Обновляет данные формы
Процедура ОбновитьДанные(НовыйЗаголовок, НовоеСообщение) Экспорт
	
	ЭтотОбъект.ТекстЗаголовка = НовыйЗаголовок;
	ЭтотОбъект.Сообщение = НовоеСообщение;
	
	// Обновляем элементы управления
	Если Элементы.Найти("ДекорацияЗаголовка") <> Неопределено Тогда
		Элементы.ДекорацияЗаголовка.Заголовок = ЭтотОбъект.ТекстЗаголовка;
	КонецЕсли;
	
	Если Элементы.Найти("ДекорацияСообщения") <> Неопределено Тогда
		Элементы.ДекорацияСообщения.Заголовок = ЭтотОбъект.Сообщение;
	КонецЕсли;
	
КонецПроцедуры







